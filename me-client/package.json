{
    "name": "@orangecheck/me-client",
    "version": "0.11.0",
    "description": "Drop-in client for me.ochk.io. Three entry points: React surface (OcSignInButton, useOcSession), server-side verification (withOcAuth for Next.js, ocAuthExpress, ocAuthHono — zero env vars, zero JWK handling), and a browser-only popup orchestrator (signInWithOc). Plus session lifecycle hooks, payment authorization, and the canonical billable-event taxonomy as types.",
    "keywords": [
        "orangecheck",
        "bitcoin",
        "identity",
        "sign-in-with-oc",
        "react",
        "sso",
        "lightning"
    ],
    "author": "OrangeCheck",
    "license": "MIT",
    "homepage": "https://me.ochk.io",
    "repository": {
        "type": "git",
        "url": "https://github.com/orangecheck/oc-packages.git",
        "directory": "me-client"
    },
    "bugs": {
        "url": "https://github.com/orangecheck/oc-packages/issues"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.mjs",
            "require": "./dist/server.js"
        },
        "./popup": {
            "types": "./dist/popup.d.ts",
            "import": "./dist/popup.mjs",
            "require": "./dist/popup.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "dependencies": {
        "@orangecheck/auth-core": "^0.4.0"
    },
    "peerDependencies": {
        "@orangecheck/auth-client": "^0.5.0",
        "express": "^4.0.0 || ^5.0.0",
        "hono": "^3.0.0 || ^4.0.0",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        },
        "hono": {
            "optional": true
        },
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@orangecheck/auth-client": "^0.5.0",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^22.0.0",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "jsdom": "^29.0.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsup": "^8.3.5",
        "typescript": "^5.6.3",
        "vitest": "^3.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
