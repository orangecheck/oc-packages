{
  "name": "@orangecheck/agent-console-client",
  "version": "0.1.0",
  "description": "Tiny HTTP client for posting OC Agent envelopes (delegations, actions, revocations, sub-delegations) to console.ochk.io. Used by every framework adapter (@orangecheck/agent-anthropic, agent-openai, agent-vercel, agent-langgraph, agent-mcp).",
  "keywords": [
    "orangecheck",
    "console",
    "agent",
    "client"
  ],
  "author": "OrangeCheck",
  "license": "MIT",
  "homepage": "https://console.ochk.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/orangecheck/oc-packages.git",
    "directory": "agent-console-client"
  },
  "bugs": {
    "url": "https://github.com/orangecheck/oc-packages/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@orangecheck/agent-core": "^0.3.0",
    "@orangecheck/agent-signer": "^0.2.0"
  },
  "devDependencies": {
    "@orangecheck/agent-core": "^0.3.0",
    "@orangecheck/agent-signer": "^0.2.0",
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
