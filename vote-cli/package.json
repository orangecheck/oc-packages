{
  "name": "@orangecheck/vote-cli",
  "version": "0.2.0",
  "description": "Command-line tool for OC Vote \u2014 tally, verify, and inspect polls from your shell.",
  "keywords": [
    "oc-vote",
    "orangecheck",
    "bitcoin",
    "voting",
    "bip322",
    "cli",
    "nostr"
  ],
  "author": "OrangeCheck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orangecheck/oc-packages.git",
    "directory": "vote-cli"
  },
  "homepage": "https://vote.ochk.io",
  "bugs": {
    "url": "https://github.com/orangecheck/oc-vote-protocol/issues"
  },
  "type": "module",
  "bin": {
    "oc-vote": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
