    "@orangecheck/lock-crypto": "^0.1.0",
    "bip322-js": "^3.0.0",
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
