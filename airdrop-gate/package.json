{
    "name": "@orangecheck/airdrop-gate",
    "version": "0.1.2",
    "description": "Sybil filter for token airdrops — turn a candidate list into a sybil-resistant allowlist backed by Bitcoin stake.",
    "keywords": [
        "orangecheck",
        "bitcoin",
        "sybil-resistance",
        "airdrop",
        "allowlist",
        "bip322",
        "nostr"
    ],
    "author": "OrangeCheck",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/orangecheck/oc-packages.git",
        "directory": "airdrop-gate"
    },
    "homepage": "https://ochk.io",
    "bugs": {
        "url": "https://github.com/orangecheck/oc-web/issues"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "oc-airdrop": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "dependencies": {
        "@orangecheck/sdk": "^0.1.3"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "tsup": "^8.3.5",
        "typescript": "^5.7.2"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
