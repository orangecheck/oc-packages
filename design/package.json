{
  "name": "@orangecheck/design",
  "version": "0.7.4",
  "description": "OrangeCheck design system — multi-theme tokens, primitives, and family composites for the .ochk.io sub-sites. Tailwind 4 + Next.js Pages Router. Not for third-party integration.",
  "keywords": [
    "orangecheck",
    "design-system",
    "ui",
    "tokens",
    "themes",
    "react",
    "internal"
  ],
  "author": "OrangeCheck",
  "license": "MIT",
  "homepage": "https://design.ochk.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/orangecheck/oc-packages.git",
    "directory": "design"
  },
  "bugs": {
    "url": "https://github.com/orangecheck/oc-packages/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.mjs",
      "require": "./dist/tokens.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.mjs",
      "require": "./dist/primitives.js"
    },
    "./composites": {
      "types": "./dist/composites.d.ts",
      "import": "./dist/composites.mjs",
      "require": "./dist/composites.js"
    },
    "./chrome": {
      "types": "./dist/chrome.d.ts",
      "import": "./dist/chrome.mjs",
      "require": "./dist/chrome.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.mjs",
      "require": "./dist/components.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.mjs",
      "require": "./dist/format.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && yarn copy:css",
    "copy:css": "rm -rf dist/styles && mkdir -p dist/styles && cp src/styles.css dist/styles.css && cp -R src/styles/. dist/styles/",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist storybook-static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "verify": "node scripts/verify-stories.mjs && node scripts/verify-themes.mjs && node scripts/verify-contrast.mjs",
    "verify:stories": "node scripts/verify-stories.mjs",
    "verify:themes": "node scripts/verify-themes.mjs",
    "verify:contrast": "node scripts/verify-contrast.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1",
    "@radix-ui/react-tabs": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "@orangecheck/auth-client": "^2.17.0",
    "lucide-react": ">=0.400.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@orangecheck/auth-client": "^2.17.0",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-themes": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@tailwindcss/vite": "^4.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.544.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "storybook": "^8.4.7",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
