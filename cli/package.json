{
  "name": "@orangecheck/cli",
  "version": "0.2.0",
  "description": "Command-line tool for OrangeCheck \u2014 check, verify, create, challenge, discover from your shell.",
  "keywords": [
    "orangecheck",
    "bitcoin",
    "sybil-resistance",
    "bip322",
    "cli",
    "nostr"
  ],
  "author": "OrangeCheck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orangecheck/oc-packages.git",
    "directory": "cli"
  },
  "homepage": "https://ochk.io",
  "bugs": {
    "url": "https://github.com/orangecheck/oc-packages/issues"
  },
  "type": "module",
  "bin": {
    "oc": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@orangecheck/me-client": "^0.22.0",
    "@orangecheck/sdk": "^0.1.3",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
